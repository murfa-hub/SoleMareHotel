@{
    ViewData["Title"] = "Занятость номеров";
}

<div style="margin-bottom: 20px;">
    <a href="/Reports" style="color: var(--teal); text-decoration: none;">← Назад к отчётам</a>
</div>

<div style="margin-bottom: 30px;">
    <h1 style="color: var(--navy); margin: 0;">Занятость номеров</h1>
    <div class="gold-line"></div>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 30px;">
    <div class="sole-card" style="text-align: center;">
        <div style="font-size: 3rem; color: var(--gold); font-weight: bold;">@ViewBag.OccupancyRate%</div>
        <div style="color: #666; margin-top: 5px;">Загруженность</div>
    </div>
    <div class="sole-card" style="text-align: center;">
        <div style="font-size: 2rem; color: var(--navy); font-weight: bold;">@ViewBag.TotalRooms</div>
        <div style="color: #666; margin-top: 5px;">Всего номеров</div>
    </div>
    <div class="sole-card" style="text-align: center;">
        <div style="font-size: 2rem; color: #c0392b; font-weight: bold;">@ViewBag.OccupiedRooms</div>
        <div style="color: #666; margin-top: 5px;">Занято</div>
    </div>
    <div class="sole-card" style="text-align: center;">
        <div style="font-size: 2rem; color: #27ae60; font-weight: bold;">@ViewBag.FreeRooms</div>
        <div style="color: #666; margin-top: 5px;">Свободно</div>
    </div>
</div>

<h3 style="color: var(--navy);">Распределение по статусам</h3>
<table class="sole-table">
    <thead>
        <tr><th>Статус</th><th>Количество</th></tr>
    </thead>
    <tbody>
        @foreach (var item in ViewBag.RoomsByStatus)
        {
                <tr><td>@((item.Status as SoleMareHotel.Models.RoomStatus?)?.GetDisplayName() ?? item.Status?.ToString())</td><td>@item.Count</td></tr>
        }
    </tbody>
</table>

<div style="margin-top: 20px;">
    <a href="/Reports/ExportOccupancyExcel" class="btn-sole-mare-fill">📥 СКАЧАТЬ EXCEL</a>
</div>