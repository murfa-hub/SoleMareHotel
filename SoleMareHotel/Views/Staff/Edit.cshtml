@model SoleMareHotel.Models.ApplicationUser

@{
    ViewData["Title"] = "Изменить сотрудника";
}

<div style="max-width: 500px; margin: 0 auto;">
    <div style="margin-bottom: 30px;">
        <h1 style="color: var(--navy); margin: 0;">Изменить: @Model.Email</h1>
        <div class="gold-line"></div>
    </div>

    <div class="sole-card">
        <form method="post" class="sole-form">
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="form-group">
                <label class="form-label">Email</label>
                <input value="@Model.Email" disabled style="background: #f5f5f5;" />
            </div>
            <div class="form-group">
                <label class="form-label">Новый пароль (оставьте пустым, если не менять)</label>
                <input name="newPassword" type="password" />
            </div>
            <div class="form-group">
                <label class="form-label">ФИО</label>
                <input name="fullName" value="@Model.FullName" required />
            </div>
            <div class="form-group">
                <label class="form-label">Роль</label>
                <select name="role">
                    <option value="">-- Выберите --</option>
                    @foreach (var role in ViewBag.Roles)
                    {
                        <option value="@role.Name" selected="@(ViewBag.UserRoles?.Contains(role.Name) == true)">
                            @if (role.Name == "Admin") { <text>Администрация отеля</text> }
                            else if (role.Name == "Receptionist") { <text>Ресепшен</text> }
                            else if (role.Name == "Housekeeper") { <text>Горничная</text> }
                            else { <text>@role.Name</text> }
                        </option>
                    }
                </select>
            </div>
            <div class="form-actions-fill">
                <button type="submit" class="btn-sole-mare-fill">СОХРАНИТЬ</button>
            </div>
        </form>
    </div>
</div>