@model IEnumerable<SoleMareHotel.Models.RoomCategory>

@{
    ViewData["Title"] = "Категории номеров";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
    <div>
        <h1 style="color: var(--navy); margin: 0;">Категории номеров</h1>
        <div class="gold-line"></div>
    </div>
    <a href="/RoomCategories/Create" class="btn-sole-mare-fill">+ ДОБАВИТЬ КАТЕГОРИЮ</a>
</div>

<table class="sole-table">
    <thead>
        <tr>
            <th>Название</th>
            <th>Описание</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Description</td>
                    <td>
                        <a href="/RoomCategories/Edit/@item.RoomCategoryId" class="table-action">Изменить</a>
                        <a href="/RoomCategories/Delete/@item.RoomCategoryId" class="table-action-danger">Удалить</a>
                    </td>
                </tr>
        }
    </tbody>
</table>