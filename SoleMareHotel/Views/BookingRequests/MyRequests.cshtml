@model IEnumerable<SoleMareHotel.Models.BookingRequest>
@using SoleMareHotel.Models

@{
    ViewData["Title"] = "Мои заявки";
}

<div style="margin-bottom: 30px;">
    <h1 style="color: var(--navy); margin: 0;">Мои заявки</h1>
    <div class="gold-line"></div>
</div>

@if (TempData["Message"] != null)
{
        <div style="background-color: #d4edda; color: #155724; padding: 15px; margin-bottom: 20px; border-left: 4px solid #155724;">@TempData["Message"]</div>
}

@if (!Model.Any())
{
        <div class="sole-card" style="text-align: center; padding: 40px;">
            <p style="color: #666; font-size: 1.1rem;">У вас пока нет заявок.</p>
            <a href="/Rooms/Catalog" class="btn-sole-mare-fill" style="display: inline-block; margin-top: 15px;">Найти номер</a>
        </div>
}
else
{
        <table class="sole-table">
            <thead>
                <tr>
                    <th>№ заявки</th>
                    <th>Номер</th>
                    <th>Заезд</th>
                    <th>Выезд</th>
                    <th>Гостей</th>
                    <th>Статус</th>
                    <th>Дата</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                        <tr>
                            <td>@item.RequestNumber</td>
                            <td>@item.Room?.RoomNumber (@item.Room?.Category?.Name)</td>
                            <td>@item.CheckIn.ToString("dd.MM.yyyy")</td>
                            <td>@item.CheckOut.ToString("dd.MM.yyyy")</td>
                            <td>@item.Guests</td>
                            <td>
                                @switch (item.Status)
                                {
                                    case RequestStatus.New: <span class="badge badge-new">@item.Status.GetDisplayName()</span> break;
                                    case RequestStatus.Confirmed: <span class="badge badge-confirmed">@item.Status.GetDisplayName()</span> break;
                                    case RequestStatus.Rejected: <span class="badge badge-rejected">@item.Status.GetDisplayName()</span> break;
                                    default: @item.Status.GetDisplayName() break;
                                }
                            </td>
                            <td>@item.CreatedAt.ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (item.Status == RequestStatus.New)
                                {
                                    <form method="post" action="/BookingRequests/Cancel" style="display: inline;" onsubmit="return confirm('Отменить заявку?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="requestId" value="@item.BookingRequestId" />
                                        <button type="submit" class="table-action-danger">Отменить</button>
                                    </form>
                                }
                            </td>
                        </tr>
            }
            </tbody>
        </table>
}
