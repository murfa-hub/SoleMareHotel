@model IEnumerable<SoleMareHotel.Models.Service>
@using SoleMareHotel.Models

@{
    ViewData["Title"] = "Услуги";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
    <div>
        <h1 style="color: var(--navy); margin: 0;">Дополнительные услуги</h1>
        <div class="gold-line"></div>
    </div>
    <a href="/Services/Create" class="btn-sole-mare-fill">+ Добавить услугу</a>
</div>

<table class="sole-table">
    <thead>
        <tr>
            <th>Название</th>
            <th>Категория</th>
            <th>Цена</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
                <tr>
                    <td>@item.Name</td>
                    <td>@(item.Category?.GetDisplayName() ?? "—")</td>
                    <td>@item.Price.ToString("N2") €</td>
                    <td>
                        <a href="/Services/Edit/@item.ServiceId" class="table-action">Изменить</a>
                        <a href="/Services/Delete/@item.ServiceId" class="table-action-danger">Удалить</a>
                    </td>
                </tr>
        }
    </tbody>
</table>