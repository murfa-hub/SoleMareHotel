@model SoleMareHotel.Models.Service
@using SoleMareHotel.Models

@{
    ViewData["Title"] = "Изменить услугу";
}

<div style="max-width: 600px; margin: 0 auto;">
    <div style="margin-bottom: 30px;">
        <h1 style="color: var(--navy); margin: 0;">Изменить услугу</h1>
        <div class="gold-line"></div>
    </div>

    <div class="sole-card">
        <form asp-action="Edit" class="sole-form">
            <input type="hidden" asp-for="ServiceId" />
            <div class="form-group">
                <label class="form-label">Название</label>
                <input asp-for="Name" required />
            </div>
            <div class="form-group">
                <label class="form-label">Категория</label>
                <select asp-for="Category">
                    <option value="">-- Выберите --</option>
                    @foreach (ServiceCategory cat in Enum.GetValues<ServiceCategory>())
                    {
                        <option value="@((int)cat)">@cat.GetDisplayName()</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Описание</label>
                <input asp-for="Description" />
            </div>
            <div class="form-group">
                <label class="form-label">Цена (€)</label>
                <input asp-for="Price" type="number" required min="0" step="0.01" />
            </div>
            <div class="form-actions">
                <button type="submit" class="btn-sole-mare-fill">СОХРАНИТЬ</button>
                <a href="/Services" class="btn-sole-mare">Отмена</a>
            </div>
        </form>
    </div>
</div>