@model SoleMareHotel.Models.Room

@{
    ViewData["Title"] = "Удалить номер";
}

<div style="max-width: 600px; margin: 0 auto;">
    <div style="margin-bottom: 30px;">
        <h1 style="color: var(--navy); margin: 0;">Удалить номер</h1>
        <div class="gold-line"></div>
    </div>

    <div class="sole-card">
        <h3 style="color: #c0392b;">Вы уверены, что хотите удалить этот номер?</h3>
        <hr />
        <p><strong>Номер:</strong> @Model.RoomNumber</p>
        <p><strong>Категория:</strong> @Model.Category?.Name</p>
        <p><strong>Этаж:</strong> @Model.Floor</p>
        <p><strong>Цена/сутки:</strong> @Model.PricePerNight.ToString("N2") €</p>

        <form asp-action="Delete" method="post" style="margin-top: 20px;">
            <input type="hidden" name="id" value="@Model.RoomId" />
            <div style="display: flex; gap: 15px;">
                <button type="submit" class="btn-sole-mare-fill" style="background-color: #c0392b !important; border-color: #c0392b !important;">УДАЛИТЬ</button>
                <a href="/Rooms" class="btn-sole-mare">ОТМЕНА</a>
            </div>
        </form>
    </div>
</div>