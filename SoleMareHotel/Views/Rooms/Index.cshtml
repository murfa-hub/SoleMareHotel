@model IEnumerable<SoleMareHotel.Models.Room>

@{
    ViewData["Title"] = "Номера";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
    <div>
        <h1 style="color: var(--navy); margin: 0;">Номерной фонд</h1>
        <div class="gold-line"></div>
    </div>
    <div style="display: flex; gap: 15px;">
        <a href="/Rooms/Create" class="btn-sole-mare-fill">+ Добавить номер</a>
        <a href="/Rooms/ExportExcel" class="btn-sole-mare">Excel</a>
    </div>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
    @foreach (var item in Model)
    {
            <div class="sole-card" style="overflow: hidden;">
            @if (!string.IsNullOrEmpty(item.PhotoPath))
            {
                        <img src="@item.PhotoPath" style="width: 100%; height: 200px; object-fit: cover;" />
            }
            else
            {
                        <div class="photo-placeholder"></div>
            }
                <div style="padding: 15px;">
                    <h3 style="color: var(--navy); margin: 0 0 5px 0;">Номер @item.RoomNumber</h3>
                    <p style="color: var(--gold); margin: 0; font-weight: bold;">@item.Category?.Name</p>
                    <p style="color: #666; margin: 10px 0;">
                        Этаж: @item.Floor | Вместимость: @item.Capacity чел.<br/>
                        Статус:
                        @switch (item.Status)
                        {
                            case RoomStatus.Free: <span class="badge badge-free">@item.Status.GetDisplayName()</span> break;
                            case RoomStatus.Occupied: <span class="badge badge-occupied">@item.Status.GetDisplayName()</span> break;
                            case RoomStatus.Cleaning: <span class="badge badge-cleaning">@item.Status.GetDisplayName()</span> break;
                            case RoomStatus.UnderRepair: <span class="badge badge-repair">@item.Status.GetDisplayName()</span> break;
                            default: @item.Status.GetDisplayName() break;
                        }
                    </p>
                @if (!string.IsNullOrEmpty(item.Description))
                {
                            <p style="color: #666; font-size: 0.9rem;">@(item.Description.Length > 100 ? item.Description.Substring(0, 100) + "..." : item.Description)</p>
                }
                    <p style="font-size: 1.3rem; color: var(--navy); font-weight: bold;">@item.PricePerNight.ToString("N2") € / сутки</p>
                    <div style="display: flex; gap: 10px; margin-top: 10px; flex-wrap: wrap;">
                        <a href="/Housekeeper/Inventory?roomId=@item.RoomId" class="table-action-gold">Опись</a>
                        <a href="/Rooms/Details/@item.RoomId" class="table-action">Подробнее</a>
                        <a href="/Rooms/Edit/@item.RoomId" class="table-action">Изменить</a>
                        @if (item.Status == RoomStatus.UnderRepair)
                        {
                            <form method="post" action="/Rooms/RestoreFromRepair" style="display: inline;" onsubmit="return confirm('Восстановить номер из ремонта?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.RoomId" />
                                <button type="submit" class="table-action-success">Восстановить</button>
                            </form>
                        }
                        else if (item.Status == RoomStatus.Free || item.Status == RoomStatus.Cleaning)
                        {
                            <form method="post" action="/Rooms/WriteOff" style="display: inline;" onsubmit="return confirm('Списать номер? Это действие потребует утверждения администрации.');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.RoomId" />
                                <button type="submit" class="table-action-danger">Списание</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
    }
</div>