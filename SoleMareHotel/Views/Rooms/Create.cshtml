@model SoleMareHotel.Models.Room
@using SoleMareHotel.Models

@{
    ViewData["Title"] = "Добавить номер";
}

<div style="max-width: 700px; margin: 0 auto;">
    <div style="margin-bottom: 30px;">
        <h1 style="color: var(--navy); margin: 0;">Новый номер</h1>
        <div class="gold-line"></div>
    </div>

    <div class="sole-card">
        <form asp-action="Create" class="sole-form" enctype="multipart/form-data">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                <div>
                    <label class="form-label">Номер комнаты</label>
                    <input asp-for="RoomNumber" required placeholder="101" />
                </div>
                <div>
                    <label class="form-label">Этаж</label>
                    <input asp-for="Floor" type="number" required min="1" />
                </div>
                <div>
                    <label class="form-label">Категория</label>
                    <select asp-for="RoomCategoryId" required>
                        <option value="">-- Выберите --</option>
                        @foreach (var cat in ViewBag.Categories)
                        {
                                <option value="@cat.RoomCategoryId">@cat.Name</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="form-label">Статус</label>
                    <select asp-for="Status" required>
                        <option value="@((int)RoomStatus.Free)">Свободен</option>
                        <option value="@((int)RoomStatus.Occupied)">Занят</option>
                        <option value="@((int)RoomStatus.Cleaning)">На уборке</option>
                        <option value="@((int)RoomStatus.UnderRepair)">На ремонте</option>
                    </select>
                </div>
                <div>
                    <label class="form-label">Вместимость (чел.)</label>
                    <input asp-for="Capacity" type="number" required min="1" max="10" />
                </div>
                <div>
                    <label class="form-label">Цена за сутки (€)</label>
                    <input asp-for="PricePerNight" type="number" required min="0" step="0.01" placeholder="150.00" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Расположение</label>
                <input asp-for="Location" placeholder="Корпус А, вид на море" />
            </div>

            <div class="form-group">
                <label class="form-label">Дополнительные удобства</label>
                <input asp-for="AdditionalAmenities" placeholder="Кондиционер, мини-бар, сейф" />
            </div>

            <div class="form-group">
                <label class="form-label">Описание номера</label>
                <textarea asp-for="Description" rows="4" placeholder="Подробное описание номера..."></textarea>
            </div>

            <div class="form-group">
                <label class="form-label">Фото номера</label>
                <input type="file" name="photo" accept="image/*" />
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-sole-mare-fill">СОХРАНИТЬ</button>
                <a href="/Rooms" class="btn-sole-mare">ОТМЕНА</a>
            </div>
        </form>
    </div>
</div>
