@model IEnumerable<SoleMareHotel.Models.Guest>

@{
    ViewData["Title"] = "Гости";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <div>
        <h1 style="color: var(--navy); margin: 0;">Картотека гостей</h1>
        <div class="gold-line"></div>
    </div>
    <div style="display: flex; gap: 15px;">
        <a href="/Guests/Create" class="btn-sole-mare-fill">+ Добавить гостя</a>
    </div>
</div>

<form method="get" style="margin-bottom: 20px; display: flex; gap: 10px;">
    <input name="search" type="text" value="@ViewBag.Search" placeholder="Поиск по ФИО, телефону, email..." style="flex: 1; padding: 12px; border: 1px solid #ccc;" />
    <button type="submit" class="btn-sole-mare-fill">Найти</button>
    @if (!string.IsNullOrEmpty(ViewBag.Search))
    {
            <a href="/Guests" class="btn-sole-mare">Сброс</a>
    }
</form>

@if (!string.IsNullOrEmpty(ViewBag.Search))
{
        <p style="color: #666; margin-bottom: 15px;">Результаты поиска: «<strong>@ViewBag.Search</strong>» — найдено: <strong>@Model.Count()</strong></p>
}

<table class="sole-table">
    <thead>
        <tr>
            <th>Карта</th>
            <th>ФИО</th>
            <th>Телефон</th>
            <th>Паспорт</th>
            <th>Дата рождения</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
                <tr>
                    <td><code>@(item.GuestCardNumber ?? "—")</code></td>
                    <td><strong>@(item.FullName ?? item.Email ?? "Гость")</strong></td>
                    <td>@item.Phone</td>
                    <td>@(item.IdentificationNumber) @(item.PassportNumber)</td>
                    <td>@(item.BirthDate?.ToString("dd.MM.yyyy") ?? "—")</td>
                    <td>
                        <a href="/Guests/Edit/@item.GuestId" class="table-action">Изменить</a>
                        <a href="/Guests/Delete/@item.GuestId" class="table-action-danger">Удалить</a>
                    </td>
                </tr>
        }
    </tbody>
</table>
