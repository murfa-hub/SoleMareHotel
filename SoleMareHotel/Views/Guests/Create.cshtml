@model SoleMareHotel.Models.Guest

@{
    ViewData["Title"] = "Добавить гостя";
}

<div style="max-width: 700px; margin: 0 auto;">
    <div style="margin-bottom: 30px;">
        <h1 style="color: var(--navy); margin: 0;">Новый гость</h1>
        <div class="gold-line"></div>
    </div>

    <div class="sole-card">
        <form asp-action="Create" class="sole-form">
            <div asp-validation-summary="All" style="color: #c0392b; margin-bottom: 20px;"></div>

            <input type="hidden" name="GuestType" value="Физическое лицо" />

            <div>
                <h3 style="color: var(--navy); margin-bottom: 15px;">Данные гостя</h3>
                <h3 style="color: var(--navy); margin-bottom: 15px;">Данные физического лица</h3>
                <div class="form-group">
                    <label class="form-label">ФИО <span style="color: #c0392b;">*</span></label>
                    <input name="FullName" placeholder="Иванов Иван Иванович" />
                </div>
                <div class="form-group" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div><label class="form-label">Идентификационный номер</label><input name="IdentificationNumber" placeholder="123456789" /></div>
                    <div><label class="form-label">Номер паспорта / код паспорта</label><input name="PassportNumber" placeholder="1234567" /></div>
                </div>
                <div class="form-group">
                    <label class="form-label">Контактный телефон <span style="color: #c0392b;">*</span></label>
                    <input name="Phone" placeholder="+3 800 123-45-67" />
                </div>
                <div class="form-group">
                    <label class="form-label">Адрес регистрации</label>
                    <input name="RegistrationAddress" placeholder="г. Минск, ул. Ленина, д. 1" />
                </div>
                <div class="form-group">
                    <label class="form-label">Дата рождения</label>
                    <input name="BirthDate" type="date" />
                </div>
            <div class="form-actions">
                <button type="submit" class="btn-sole-mare-fill">СОХРАНИТЬ</button>
                <a href="/Guests" class="btn-sole-mare">ОТМЕНА</a>
            </div>
        </form>
    </div>
</div>