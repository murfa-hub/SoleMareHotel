@{
    ViewData["Title"] = "Добавить услуги";
    var services = ViewBag.Services as List<SoleMareHotel.Models.Service>;
}

<div style="max-width: 700px; margin: 0 auto;">
    <div style="margin-bottom: 30px;">
        <h1 style="color: var(--navy); margin: 0;">Добавить услуги в лицевой счёт</h1>
        <div class="gold-line"></div>
    </div>

    <div class="sole-card">
        <form asp-action="Create" class="sole-form" id="serviceForm">
            <input type="hidden" name="BookingId" value="@ViewBag.BookingId" />

            <div id="servicesContainer">
                <div class="service-row" style="display: grid; grid-template-columns: 2fr 1fr 1fr 40px; gap: 10px; margin-bottom: 15px; align-items: end;">
                    <div>
                        <label style="font-weight: 600; display: block; margin-bottom: 5px;">Услуга</label>
                        <select name="services[0].ServiceId" required class="service-select" style="width: 100%; padding: 12px;">
                            <option value="">-- Выберите --</option>
                            @foreach (var s in services ?? new())
                            {
                                    <option value="@s.ServiceId" data-price="@s.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)">@s.Name — @s.Price.ToString("N0") €</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label style="font-weight: 600; display: block; margin-bottom: 5px;">Кол-во</label>
                        <input name="services[0].Quantity" type="number" value="1" min="1" class="quantity-input" style="width: 100%; padding: 12px;" />
                    </div>
                    <div>
                        <label style="font-weight: 600; display: block; margin-bottom: 5px;">Цена (€)</label>
                        <input name="services[0].Price" type="number" step="0.01" value="0" readonly class="price-input" style="width: 100%; padding: 12px; background-color: #f5f5f5;" />
                    </div>
                    <div>
                        <button type="button" onclick="removeRow(this)" style="background: none; border: none; color: #c0392b; font-size: 1.5rem; cursor: pointer;" title="Удалить">×</button>
                    </div>
                </div>
            </div>

            <button type="button" onclick="addRow()" class="btn-sole-mare" style="margin-bottom: 20px;">+ ДОБАВИТЬ ЕЩЁ УСЛУГУ</button>

            <div style="margin-bottom: 15px;">
                <label style="font-weight: 600; display: block; margin-bottom: 5px;">Дата заказа</label>
                <input name="OrderDate" type="datetime-local" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" style="padding: 12px;" />
            </div>

            <button type="submit" class="btn-sole-mare-fill" style="width: 100%;">💾 СОХРАНИТЬ ВСЕ УСЛУГИ</button>
        </form>
    </div>
</div>

<script>
    var rowCount = 1;
    function addRow() {
        var container = document.getElementById('servicesContainer');
        var html = `<div class="service-row" style="display: grid; grid-template-columns: 2fr 1fr 1fr 40px; gap: 10px; margin-bottom: 15px; align-items: end;">
            <div>
                <select name="services[${rowCount}].ServiceId" required class="service-select" style="width: 100%; padding: 12px;">
                    <option value="">-- Выберите --</option>
    @foreach (var s in services ?? new())
    {
                            <option value="@s.ServiceId" data-price="@s.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)">@s.Name — @s.Price.ToString("N0") €</option>
    }
                </select>
            </div>
            <div>
                <input name="services[${rowCount}].Quantity" type="number" value="1" min="1" class="quantity-input" style="width: 100%; padding: 12px;" />
            </div>
            <div>
                <input name="services[${rowCount}].Price" type="number" step="0.01" value="0" readonly class="price-input" style="width: 100%; padding: 12px; background-color: #f5f5f5;" />
            </div>
            <div>
                <button type="button" onclick="removeRow(this)" style="background: none; border: none; color: #c0392b; font-size: 1.5rem; cursor: pointer;">×</button>
            </div>
        </div>`;
        container.insertAdjacentHTML('beforeend', html);
        rowCount++;
    }
    function removeRow(btn) {
        btn.closest('.service-row').remove();
    }
    document.addEventListener('change', function (e) {
        if (e.target.classList.contains('service-select')) {
            var option = e.target.options[e.target.selectedIndex];
            var price = option.getAttribute('data-price');
            var row = e.target.closest('.service-row');
            var priceInput = row.querySelector('.price-input');
            if (price && priceInput) {
                priceInput.value = price;
            }
        }
    });
</script>